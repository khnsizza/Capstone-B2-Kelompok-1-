# QRIS Inquiry Service — Environment Configuration
#
# Copy this file to .env and fill in the real credentials.
# The service reads these via std::env::var() at startup.

# PostgreSQL connection string
# Format: postgres://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgres://postgres:postgres@localhost:5432/qris_db

# Redis connection string
REDIS_URL=redis://127.0.0.1:6379/

# Rocket port (default: 8000)
ROCKET_PORT=8000

# Log verbosity — uses tracing-subscriber EnvFilter syntax.
# Examples:
#   info                        — general info from all crates
#   capstone2=debug             — debug from this crate only
#   capstone2=debug,rocket=warn — noisy Rocket logs suppressed
RUST_LOG=capstone2=info,rocket=warn
